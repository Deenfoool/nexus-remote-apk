{
  "manifest_version": 3,
  "name": "Nexus Remote Browser Bridge",
  "short_name": "Nexus Remote",
  "version": "1.0.0",
  "description": "Connect browser media tabs to Nexus Remote PC.",
  "browser_specific_settings": {
    "gecko": {
      "id": "browser-bridge@nexusremote.app",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "121.0"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://127.0.0.1:8767 http://localhost:8767"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://youtube.com/*",
    "https://music.youtube.com/*",
    "https://vk.com/*",
    "https://*.vk.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://youtube.com/*",
        "https://music.youtube.com/*",
        "https://vk.com/*",
        "https://*.vk.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Nexus Remote Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  }
}
