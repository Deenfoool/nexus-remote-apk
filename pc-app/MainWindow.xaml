<Window x:Class="NexusRemotePC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexus Remote" Height="820" Width="1024" MinHeight="760" MinWidth="940"
        WindowStartupLocation="CenterScreen" Background="#07101D">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101F31"/>
        <SolidColorBrush x:Key="PanelStroke" Color="#22344C"/>
        <SolidColorBrush x:Key="TextMain" Color="#F4F8FF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#A7B4C6"/>
        <SolidColorBrush x:Key="Accent" Color="#28DDF0"/>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F4F8FF"/>
            <Setter Property="Background" Value="#13263B"/>
            <Setter Property="BorderBrush" Value="#2A4767"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F4F8FF"/>
            <Setter Property="Background" Value="#0B1726"/>
            <Setter Property="BorderBrush" Value="#263C56"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*"/>
            <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" Margin="0,0,24,0" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Nexus Remote" FontSize="34" FontWeight="Bold"/>
            <TextBlock Text="Компаньон для подключения телефона к этому ПК" Foreground="{StaticResource TextMuted}"
                       FontSize="16" Margin="0,8,0,26"/>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelStroke}"
                    BorderThickness="1" CornerRadius="18" Padding="22" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Статус" FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="StatusText" Text="Запуск..." Foreground="{StaticResource Accent}"
                               FontSize="16" Margin="0,8,0,18"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Версия" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="VersionText" Grid.Column="1" IsReadOnly="True"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="IP" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="IpText" Grid.Column="1" IsReadOnly="True"/>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Порт" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="PortText" Grid.Column="1" IsReadOnly="True"/>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pairing" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="TokenText" Grid.Column="1" IsReadOnly="True"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelStroke}"
                    BorderThickness="1" CornerRadius="18" Padding="22">
                <StackPanel>
                    <TextBlock Text="Управление" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    <UniformGrid Columns="2" Rows="3">
                        <Button Content="Обновить QR" Margin="0,0,8,10" Click="Refresh_Click"/>
                        <Button Content="Сбросить устройства" Margin="8,0,0,10" Click="ResetDevices_Click"/>
                        <Button Content="Менеджер программ" Margin="0,0,8,10" Click="Programs_Click"/>
                        <Button Content="Удалить устройство" Margin="8,0,0,10" Click="RemoveDevice_Click"/>
                        <Button Content="Свернуть в трей" Margin="0,0,8,0" Click="Hide_Click"/>
                        <Button Content="Выйти" Margin="8,0,0,0" Click="Exit_Click"/>
                    </UniformGrid>
                    <TextBlock Text="Доверенные устройства" FontSize="17" FontWeight="Bold" Margin="0,18,0,10"/>
                    <ListView x:Name="DevicesList" Height="96" Background="#0B1726" BorderBrush="#263C56" Foreground="{StaticResource TextMain}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding Name}" Width="190"/>
                                <GridViewColumn Header="Последний доступ" DisplayMemberBinding="{Binding LastSeenAt}" Width="210"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <CheckBox x:Name="AutostartCheck" Content="Запускать вместе с Windows"
                              Foreground="{StaticResource TextMain}" FontSize="15" Margin="0,18,0,0"
                              Checked="AutostartCheck_Changed" Unchecked="AutostartCheck_Changed"/>
                    <TextBlock Text="Последние события" FontSize="17" FontWeight="Bold" Margin="0,18,0,10"/>
                    <ListView x:Name="EventsList" Height="112" Background="#0B1726" BorderBrush="#263C56" Foreground="{StaticResource TextMain}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Время" DisplayMemberBinding="{Binding CreatedAt}" Width="92"/>
                                <GridViewColumn Header="Тип" DisplayMemberBinding="{Binding Level}" Width="82"/>
                                <GridViewColumn Header="Сообщение" DisplayMemberBinding="{Binding Message}" Width="270"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <TextBlock Text="Логи и ошибки" FontSize="17" FontWeight="Bold" Margin="0,18,0,10"/>
                    <TextBox x:Name="LogsText"
                             Height="148"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"/>
                    <DockPanel Margin="0,12,0,0">
                        <Button Content="Открыть папку логов" DockPanel.Dock="Left" Click="OpenLogs_Click"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Проверить обновления" Margin="0,0,10,0" Click="CheckUpdates_Click"/>
                            <Button Content="Обновить логи" Click="RefreshLogs_Click"/>
                        </StackPanel>
                    </DockPanel>
                    <TextBlock x:Name="UpdateStatusText" Foreground="{StaticResource TextMuted}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelStroke}"
                BorderThickness="1" CornerRadius="24" Padding="28">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="QR сопряжения" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Открой Nexus Remote на телефоне, нажми “Сканировать QR” и наведи камеру на код."
                           Foreground="{StaticResource TextMuted}" TextAlignment="Center" FontSize="15"
                           Margin="0,8,0,22" Width="330"/>
                <Border Background="#F7FBFF" CornerRadius="18" Padding="16">
                    <Image x:Name="QrImage" Width="300" Height="300"/>
                </Border>
                <TextBlock Text="Сервер принимает подключения только из локальной сети."
                           Foreground="{StaticResource TextMuted}" TextAlignment="Center" Margin="0,22,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
